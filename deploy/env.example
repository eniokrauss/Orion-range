# ── Core ──────────────────────────────────────────────────────────────────────
ORION_ENV=dev
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://orion:orion@postgres:5432/orion
API_KEY=

# ── Hypervisor ────────────────────────────────────────────────────────────────
HYPERVISOR_PROVIDER=proxmox

# ── Proxmox Connection ────────────────────────────────────────────────────────
# Leave PROXMOX_HOST empty to run in dry-run mode (no real VMs are created).
PROXMOX_HOST=
PROXMOX_PORT=8006
PROXMOX_USER=root@pam
# Create an API token in Proxmox: Datacenter > Permissions > API Tokens
# Token format: <user>@<realm>!<tokenname>  e.g. root@pam!orion
PROXMOX_TOKEN_NAME=
PROXMOX_TOKEN_VALUE=
PROXMOX_VERIFY_SSL=false
PROXMOX_NODE=pve

# ── Proxmox Operation Timeouts (seconds) ─────────────────────────────────────
PROXMOX_TASK_POLL_INTERVAL=3.0
PROXMOX_TASK_TIMEOUT=300
PROXMOX_PROVISION_TIMEOUT=600
PROXMOX_SNAPSHOT_TIMEOUT=120
PROXMOX_RESET_TIMEOUT=180

# ── Proxmox Resource Naming ───────────────────────────────────────────────────
PROXMOX_VM_NAME_PREFIX=orion
PROXMOX_STORAGE=local-lvm
PROXMOX_DEFAULT_TEMPLATE_VMID=9000

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate a strong secret: python3 -c "import secrets; print(secrets.token_hex(32))"
# Leave empty in dev to use open/unauthenticated mode.
JWT_SECRET=
# Optional fallback secrets for key rotation (comma-separated). Old tokens signed
# with these secrets remain valid while you migrate clients to JWT_SECRET.
JWT_SECRET_FALLBACKS=
# Optional JWT claim hardening. When set, issued tokens include these claims and
# incoming tokens must match.
JWT_ISSUER=
JWT_AUDIENCE=
# Allowed clock skew while validating exp/iat claims.
JWT_CLOCK_SKEW_SECONDS=30

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_FORMAT=json  → structured JSON lines (auto-enabled in prod/staging)
# LOG_FORMAT=      → human-readable text (default in dev)
LOG_FORMAT=
